  { "id": "s_a1_231", "level": "A1", "english": "Think about it {tomorrow}.", "korean": "내일 생각해 봐.", "cloze": ["tomorrow"], "tags": ["expression"] },
  { "id": "s_a1_232", "level": "A1", "english": "Turns out he's {right}.", "korean": "알고 보니 그가 맞아.", "cloze": ["right"], "tags": ["expression"] },
  { "id": "s_a1_233", "level": "A1", "english": "Actually, I'm {tired}.", "korean": "사실 피곤해.", "cloze": ["tired"], "tags": ["expression"] },
  { "id": "s_a1_234", "level": "A1", "english": "Fact is, I {forgot}.", "korean": "실은 잊었어.", "cloze": ["forgot"], "tags": ["expression"] },
  { "id": "s_a1_235", "level": "A1", "english": "Thing is, I'm {hungry}.", "korean": "근데 말이야, 배고파.", "cloze": ["hungry"], "tags": ["expression"] },
  { "id": "s_a1_236", "level": "A1", "english": "I was like, '{help} me!'", "korean": "이렇게 말했지, '도와줘!'", "cloze": ["help"], "tags": ["expression"] },
  { "id": "s_a1_237", "level": "A1", "english": "Chances are, he's {late}.", "korean": "아마 늦을 거야.", "cloze": ["late"], "tags": ["expression"] },
  { "id": "s_a1_238", "level": "A1", "english": "What are you, a {kid}?", "korean": "네가 무슨 어린애야?", "cloze": ["kid"], "tags": ["expression"] },
  { "id": "s_a1_239", "level": "A1", "english": "For your information, I {work} hard.", "korean": "몰라서 그런 것 같은데, 난 열심히 일해.", "cloze": ["work"], "tags": ["expression"] },
  { "id": "s_a1_240", "level": "A1", "english": "I'm just {tired}, that's all.", "korean": "그냥 피곤해서 그래.", "cloze": ["tired"], "tags": ["expression"] },
  { "id": "s_a1_241", "level": "A1", "english": "You {OK}, by any chance?", "korean": "혹시 괜찮아?", "cloze": ["OK"], "tags": ["expression"] },
  { "id": "s_a1_242", "level": "A1", "english": "He's {sick}, or something.", "korean": "아픈가 그런가 봐.", "cloze": ["sick"], "tags": ["expression"] },
  { "id": "s_a1_243", "level": "A1", "english": "Sleep is your {best} bet.", "korean": "잠이 최선이야.", "cloze": ["best"], "tags": ["expression"] },
  { "id": "s_a1_244", "level": "A1", "english": "You're {tired}, maybe.", "korean": "피곤한 것일 수도.", "cloze": ["tired"], "tags": ["expression"] },
  { "id": "s_a1_245", "level": "A1", "english": "That's {family} for you.", "korean": "가족은 원래 그래.", "cloze": ["family"], "tags": ["expression"] },
  { "id": "s_a1_246", "level": "A1", "english": "Some {dress} you got there.", "korean": "그 드레스 정말 멋진데요.", "cloze": ["dress"], "tags": ["expression"] },
  { "id": "s_a1_247", "level": "A1", "english": "Why he's {sad} is beyond me.", "korean": "왜 슬픈지 알 수가 없네.", "cloze": ["sad"], "tags": ["expression"] },
  { "id": "s_a1_248", "level": "A1", "english": "How does {pizza} sound?", "korean": "피자 어때?", "cloze": ["pizza"], "tags": ["expression"] },
  { "id": "s_a1_249", "level": "A1", "english": "How {old} is that?", "korean": "얼마나 오래됐어?", "cloze": ["old"], "tags": ["expression"] },
  { "id": "s_a1_250", "level": "A1", "english": "Just {try}, will ya?", "korean": "한번 해 봐, 응?", "cloze": ["try"], "tags": ["expression"] }
