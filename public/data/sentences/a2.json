  { "id": "s_a2_107", "level": "A2", "english": "I'm sorry to {hear} that.", "korean": "그 얘기 들어서 안타깝네요.", "cloze": ["hear"], "tags": ["emotion"] },
  { "id": "s_a2_108", "level": "A2", "english": "Don't {worry} about it.", "korean": "걱정하지 마세요.", "cloze": ["worry"], "tags": ["emotion"] },
  { "id": "s_a2_109", "level": "A2", "english": "I really {appreciate} it.", "korean": "정말 감사해요.", "cloze": ["appreciate"], "tags": ["emotion"] },
  { "id": "s_a2_110", "level": "A2", "english": "I'm a bit {nervous} about it.", "korean": "그것 때문에 좀 긴장돼요.", "cloze": ["nervous"], "tags": ["emotion"] },
  { "id": "s_a2_111", "level": "A2", "english": "I'm feeling {lonely} today.", "korean": "오늘 좀 외로워요.", "cloze": ["lonely"], "tags": ["emotion"] },
  { "id": "s_a2_112", "level": "A2", "english": "Cheer up, it'll get {better}.", "korean": "기운 내요, 더 나아질 거예요.", "cloze": ["better"], "tags": ["emotion"] },
  { "id": "s_a2_113", "level": "A2", "english": "I {missed} you so much.", "korean": "정말 보고 싶었어요.", "cloze": ["missed"], "tags": ["emotion"] },
  { "id": "s_a2_114", "level": "A2", "english": "I {hope} you feel better soon.", "korean": "빨리 나으시길 바라요.", "cloze": ["hope"], "tags": ["emotion"] },
  { "id": "s_a2_115", "level": "A2", "english": "I {wish} you good luck.", "korean": "행운을 빌어요.", "cloze": ["wish"], "tags": ["emotion"] },
  { "id": "s_a2_116", "level": "A2", "english": "What are you going to {do} tomorrow?", "korean": "내일 뭐 하실 거예요?", "cloze": ["do"], "tags": ["future"] },
  { "id": "s_a2_117", "level": "A2", "english": "I'm going to {visit} my parents.", "korean": "부모님 댁에 갈 거예요.", "cloze": ["visit"], "tags": ["future"] },
  { "id": "s_a2_118", "level": "A2", "english": "I'll {call} you later.", "korean": "나중에 전화할게요.", "cloze": ["call"], "tags": ["future"] },
  { "id": "s_a2_119", "level": "A2", "english": "I'll {let} you know.", "korean": "알려 드릴게요.", "cloze": ["let"], "tags": ["future"] },
  { "id": "s_a2_120", "level": "A2", "english": "We'll {meet} again next month.", "korean": "다음 달에 다시 만나요.", "cloze": ["meet"], "tags": ["future"] },
  { "id": "s_a2_121", "level": "A2", "english": "I {might} go shopping later.", "korean": "이따 쇼핑 갈 수도 있어요.", "cloze": ["might"], "tags": ["future"] },
  { "id": "s_a2_122", "level": "A2", "english": "I {may} be late tomorrow.", "korean": "내일 좀 늦을 수도 있어요.", "cloze": ["may"], "tags": ["future"] },
  { "id": "s_a2_123", "level": "A2", "english": "I {used} to live in Busan.", "korean": "예전에 부산에 살았어요.", "cloze": ["used"], "tags": ["past"] },
  { "id": "s_a2_124", "level": "A2", "english": "I {haven't} seen her in years.", "korean": "그녀를 몇 년째 못 봤어요.", "cloze": ["haven't"], "tags": ["past"] },
  { "id": "s_a2_125", "level": "A2", "english": "Have you {ever} been to Japan?", "korean": "일본에 가 본 적 있어요?", "cloze": ["ever"], "tags": ["past"] },
  { "id": "s_a2_126", "level": "A2", "english": "Yes, I went {there} last year.", "korean": "네, 작년에 거기 갔어요.", "cloze": ["there"], "tags": ["past"] },
  { "id": "s_a2_127", "level": "A2", "english": "I've never {tried} that food.", "korean": "그 음식 한 번도 먹어 본 적 없어요.", "cloze": ["tried"], "tags": ["past"] },
  { "id": "s_a2_128", "level": "A2", "english": "I've {just} finished work.", "korean": "방금 일을 끝냈어요.", "cloze": ["just"], "tags": ["past"] },
  { "id": "s_a2_129", "level": "A2", "english": "I've {already} eaten lunch.", "korean": "벌써 점심 먹었어요.", "cloze": ["already"], "tags": ["past"] },
  { "id": "s_a2_130", "level": "A2", "english": "I haven't done it {yet}.", "korean": "아직 안 했어요.", "cloze": ["yet"], "tags": ["past"] },
  { "id": "s_a2_131", "level": "A2", "english": "When did this {happen}?", "korean": "이거 언제 일어났어요?", "cloze": ["happen"], "tags": ["past"] },
  { "id": "s_a2_132", "level": "A2", "english": "It happened a few days {ago}.", "korean": "며칠 전에 그랬어요.", "cloze": ["ago"], "tags": ["past"] },
  { "id": "s_a2_133", "level": "A2", "english": "What time will you {arrive}?", "korean": "몇 시에 도착하세요?", "cloze": ["arrive"], "tags": ["time"] },
  { "id": "s_a2_134", "level": "A2", "english": "I'll {be} there in ten minutes.", "korean": "10분 안에 갈게요.", "cloze": ["be"], "tags": ["time"] },
  { "id": "s_a2_135", "level": "A2", "english": "We need to leave {by} six.", "korean": "6시까지 출발해야 해요.", "cloze": ["by"], "tags": ["time"] },
  { "id": "s_a2_136", "level": "A2", "english": "Let's meet {at} the cafe.", "korean": "카페에서 만나요.", "cloze": ["at"], "tags": ["time"] },
  { "id": "s_a2_137", "level": "A2", "english": "Can we {reschedule} for Friday?", "korean": "금요일로 일정 변경 가능해요?", "cloze": ["reschedule"], "tags": ["time"] },
  { "id": "s_a2_138", "level": "A2", "english": "Sorry, I have another {appointment}.", "korean": "죄송해요, 다른 약속이 있어요.", "cloze": ["appointment"], "tags": ["time"] },
  { "id": "s_a2_139", "level": "A2", "english": "Are you {free} this afternoon?", "korean": "오늘 오후에 시간 있어요?", "cloze": ["free"], "tags": ["time"] },
  { "id": "s_a2_140", "level": "A2", "english": "Let's set a {time} that works for both of us.", "korean": "둘 다 괜찮은 시간으로 정해요.", "cloze": ["time"], "tags": ["time"] },
  { "id": "s_a2_141", "level": "A2", "english": "I work out {three} times a week.", "korean": "일주일에 세 번 운동해요.", "cloze": ["three"], "tags": ["frequency"] },
  { "id": "s_a2_142", "level": "A2", "english": "I {hardly} ever drink coffee.", "korean": "저는 커피를 거의 안 마셔요.", "cloze": ["hardly"], "tags": ["frequency"] },
  { "id": "s_a2_143", "level": "A2", "english": "I {sometimes} stay up late.", "korean": "가끔 늦게까지 안 자요.", "cloze": ["sometimes"], "tags": ["frequency"] },
  { "id": "s_a2_144", "level": "A2", "english": "She is {taller} than her brother.", "korean": "그녀는 오빠보다 키가 더 커요.", "cloze": ["taller"], "tags": ["comparison"] },
  { "id": "s_a2_145", "level": "A2", "english": "This bag is {cheaper} than that one.", "korean": "이 가방이 저것보다 더 싸요.", "cloze": ["cheaper"], "tags": ["comparison"] },
  { "id": "s_a2_146", "level": "A2", "english": "Korean food is {spicier} than I expected.", "korean": "한국 음식은 생각보다 더 매워요.", "cloze": ["spicier"], "tags": ["comparison"] },
  { "id": "s_a2_147", "level": "A2", "english": "This is the {best} pizza in town.", "korean": "이게 동네에서 제일 맛있는 피자예요.", "cloze": ["best"], "tags": ["comparison"] },
  { "id": "s_a2_148", "level": "A2", "english": "It's the {worst} movie I've seen.", "korean": "내가 본 영화 중 최악이에요.", "cloze": ["worst"], "tags": ["comparison"] },
  { "id": "s_a2_149", "level": "A2", "english": "She's the {most} kind person I know.", "korean": "그녀는 내가 아는 가장 친절한 사람이에요.", "cloze": ["most"], "tags": ["comparison"] },
  { "id": "s_a2_150", "level": "A2", "english": "My phone is as {old} as yours.", "korean": "내 폰은 네 거만큼 오래됐어.", "cloze": ["old"], "tags": ["comparison"] },
  { "id": "s_a2_151", "level": "A2", "english": "I love this place {more} than the other one.", "korean": "다른 곳보다 여기가 더 좋아요.", "cloze": ["more"], "tags": ["comparison"] },
  { "id": "s_a2_152", "level": "A2", "english": "Less salt would be {better}.", "korean": "소금 덜 넣는 게 좋겠어요.", "cloze": ["better"], "tags": ["comparison"] },
  { "id": "s_a2_153", "level": "A2", "english": "I'd rather {stay} home tonight.", "korean": "오늘 밤은 집에 있을래요.", "cloze": ["stay"], "tags": ["preference"] },
  { "id": "s_a2_154", "level": "A2", "english": "Could you {help} me with this?", "korean": "이것 좀 도와주실 수 있어요?", "cloze": ["help"], "tags": ["request"] },
  { "id": "s_a2_155", "level": "A2", "english": "Would you {mind} closing the window?", "korean": "창문 좀 닫아 주실래요?", "cloze": ["mind"], "tags": ["request"] },
  { "id": "s_a2_156", "level": "A2", "english": "Do you {mind} if I sit here?", "korean": "여기 앉아도 될까요?", "cloze": ["mind"], "tags": ["request"] },
  { "id": "s_a2_157", "level": "A2", "english": "Could you {speak} more slowly?", "korean": "조금 더 천천히 말해 주실 수 있어요?", "cloze": ["speak"], "tags": ["request"] },
  { "id": "s_a2_158", "level": "A2", "english": "Could you {repeat} that, please?", "korean": "다시 한번 말씀해 주시겠어요?", "cloze": ["repeat"], "tags": ["request"] },
  { "id": "s_a2_159", "level": "A2", "english": "Can I ask you a {favor}?", "korean": "부탁 하나 해도 될까요?", "cloze": ["favor"], "tags": ["request"] },
  { "id": "s_a2_160", "level": "A2", "english": "Would you {like} some help?", "korean": "도움이 필요하세요?", "cloze": ["like"], "tags": ["request"] },
  { "id": "s_a2_161", "level": "A2", "english": "Let me {know} if you need anything.", "korean": "필요한 거 있으면 알려 주세요.", "cloze": ["know"], "tags": ["request"] },
  { "id": "s_a2_162", "level": "A2", "english": "Why don't we {try} that new place?", "korean": "새로 생긴 그 가게 가 볼래요?", "cloze": ["try"], "tags": ["suggestion"] },
  { "id": "s_a2_163", "level": "A2", "english": "How {about} going to the movies?", "korean": "영화 보러 가는 거 어때요?", "cloze": ["about"], "tags": ["suggestion"] },
  { "id": "s_a2_164", "level": "A2", "english": "Let's {grab} a coffee.", "korean": "커피 한 잔 해요.", "cloze": ["grab"], "tags": ["suggestion"] },
  { "id": "s_a2_165", "level": "A2", "english": "You should {try} this dish.", "korean": "이 요리 꼭 드셔 보세요.", "cloze": ["try"], "tags": ["suggestion"] },
  { "id": "s_a2_166", "level": "A2", "english": "I {agree} with you.", "korean": "저도 그렇게 생각해요.", "cloze": ["agree"], "tags": ["opinion"] },
  { "id": "s_a2_167", "level": "A2", "english": "I {disagree} with that idea.", "korean": "그 생각에 동의하지 않아요.", "cloze": ["disagree"], "tags": ["opinion"] },
  { "id": "s_a2_168", "level": "A2", "english": "In my {opinion}, it's a great idea.", "korean": "제 생각에는 정말 좋은 아이디어예요.", "cloze": ["opinion"], "tags": ["opinion"] },
  { "id": "s_a2_169", "level": "A2", "english": "I {believe} you're right.", "korean": "당신 말이 맞다고 생각해요.", "cloze": ["believe"], "tags": ["opinion"] },
  { "id": "s_a2_170", "level": "A2", "english": "That's a good {point}.", "korean": "좋은 지적이네요.", "cloze": ["point"], "tags": ["opinion"] },
  { "id": "s_a2_171", "level": "A2", "english": "I'm not {sure} about that.", "korean": "그건 잘 모르겠어요.", "cloze": ["sure"], "tags": ["opinion"] },
  { "id": "s_a2_172", "level": "A2", "english": "It {depends} on the situation.", "korean": "상황에 따라 달라요.", "cloze": ["depends"], "tags": ["opinion"] },
  { "id": "s_a2_173", "level": "A2", "english": "I {decided} to study English.", "korean": "영어 공부하기로 결정했어요.", "cloze": ["decided"], "tags": ["decision"] },
  { "id": "s_a2_174", "level": "A2", "english": "I {chose} the blue one.", "korean": "저는 파란 걸로 골랐어요.", "cloze": ["chose"], "tags": ["decision"] },
  { "id": "s_a2_175", "level": "A2", "english": "What's your {decision}?", "korean": "결정하셨어요?", "cloze": ["decision"], "tags": ["decision"] },
  { "id": "s_a2_176", "level": "A2", "english": "Could you {explain} that again?", "korean": "그거 다시 한번 설명해 주실래요?", "cloze": ["explain"], "tags": ["communication"] },
  { "id": "s_a2_177", "level": "A2", "english": "I'll {describe} it to you.", "korean": "제가 설명해 드릴게요.", "cloze": ["describe"], "tags": ["communication"] },
  { "id": "s_a2_178", "level": "A2", "english": "What does this word {mean}?", "korean": "이 단어는 무슨 뜻이에요?", "cloze": ["mean"], "tags": ["communication"] },
  { "id": "s_a2_179", "level": "A2", "english": "How do you {say} this in English?", "korean": "이걸 영어로 어떻게 말해요?", "cloze": ["say"], "tags": ["communication"] },
  { "id": "s_a2_180", "level": "A2", "english": "I don't {understand} the question.", "korean": "질문을 이해 못 했어요.", "cloze": ["understand"], "tags": ["communication"] },
  { "id": "s_a2_181", "level": "A2", "english": "Could you write it {down}?", "korean": "그거 적어 주실 수 있어요?", "cloze": ["down"], "tags": ["communication"] },
  { "id": "s_a2_182", "level": "A2", "english": "I'll {send} you a message.", "korean": "메시지 보낼게요.", "cloze": ["send"], "tags": ["communication"] },
  { "id": "s_a2_183", "level": "A2", "english": "I'll {text} you the address.", "korean": "주소 문자로 보낼게요.", "cloze": ["text"], "tags": ["communication"] },
  { "id": "s_a2_184", "level": "A2", "english": "Did you get my {email}?", "korean": "제 이메일 받으셨어요?", "cloze": ["email"], "tags": ["communication"] },
  { "id": "s_a2_185", "level": "A2", "english": "Sorry, I missed your {call}.", "korean": "죄송해요, 전화 못 받았어요.", "cloze": ["call"], "tags": ["communication"] },
  { "id": "s_a2_186", "level": "A2", "english": "I'll {call} you back later.", "korean": "이따 다시 전화할게요.", "cloze": ["call"], "tags": ["communication"] },
  { "id": "s_a2_187", "level": "A2", "english": "My phone is {dying}.", "korean": "폰 배터리가 거의 다 됐어요.", "cloze": ["dying"], "tags": ["tech"] },
  { "id": "s_a2_188", "level": "A2", "english": "Do you have a {charger}?", "korean": "충전기 있으세요?", "cloze": ["charger"], "tags": ["tech"] },
  { "id": "s_a2_189", "level": "A2", "english": "The {signal} is weak here.", "korean": "여기 신호가 약해요.", "cloze": ["signal"], "tags": ["tech"] },
  { "id": "s_a2_190", "level": "A2", "english": "Can you {send} me the link?", "korean": "링크 좀 보내 주실 수 있어요?", "cloze": ["send"], "tags": ["tech"] },
  { "id": "s_a2_191", "level": "A2", "english": "I'll {check} my email later.", "korean": "나중에 이메일 확인할게요.", "cloze": ["check"], "tags": ["tech"] },
  { "id": "s_a2_192", "level": "A2", "english": "I {can't} log in.", "korean": "로그인이 안 돼요.", "cloze": ["can't"], "tags": ["tech"] },
  { "id": "s_a2_193", "level": "A2", "english": "I {forgot} my password.", "korean": "비밀번호를 잊어버렸어요.", "cloze": ["forgot"], "tags": ["tech"] },
  { "id": "s_a2_194", "level": "A2", "english": "Could you {help} me find it?", "korean": "찾는 거 좀 도와주실래요?", "cloze": ["help"], "tags": ["request"] },
  { "id": "s_a2_195", "level": "A2", "english": "I {need} to make an appointment.", "korean": "예약을 잡아야 해요.", "cloze": ["need"], "tags": ["health"] },
  { "id": "s_a2_196", "level": "A2", "english": "I have a {headache}.", "korean": "머리가 아파요.", "cloze": ["headache"], "tags": ["health"] },
  { "id": "s_a2_197", "level": "A2", "english": "I think I have a {fever}.", "korean": "열이 나는 것 같아요.", "cloze": ["fever"], "tags": ["health"] },
  { "id": "s_a2_198", "level": "A2", "english": "I have a sore {throat}.", "korean": "목이 아파요.", "cloze": ["throat"], "tags": ["health"] },
  { "id": "s_a2_199", "level": "A2", "english": "Do you have any {medicine} for a cough?", "korean": "기침약 있어요?", "cloze": ["medicine"], "tags": ["health"] },
  { "id": "s_a2_200", "level": "A2", "english": "Take care and get {better} soon.", "korean": "몸조리 잘하시고 빨리 나으세요.", "cloze": ["better"], "tags": ["health"] }
