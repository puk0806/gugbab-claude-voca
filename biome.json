{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "extends": ["@gugbab/biome-config/base.json"],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "!**/dist",
      "!**/coverage",
      "!**/node_modules",
      "!pnpm-lock.yaml",
      "!**/.claude",
      "!docs/design/scenarios.html",
      "!e2e/visual/__screenshots__",
      "!playwright-report",
      "!test-results"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": { "level": "warn", "options": { "allow": ["warn", "error"] } }
      },
      "style": {
        "useImportType": "error",
        "useConst": "error",
        "noNonNullAssertion": "error",
        "useNodejsImportProtocol": "error",
        "useTemplate": "error"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "complexity": {
        "noUselessTypeConstraint": "error",
        "noBannedTypes": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.{ts,tsx}", "src/__tests__/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
